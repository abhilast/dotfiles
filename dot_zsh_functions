  echo "🔄 Reloading ZSH completion system..."
  
  # Remove old completion dump
  [[ -f ~/.zcompdump ]] && rm ~/.zcompdump
  
  # Reinitialize completion system
  autoload -Uz compinit
  compinit
  
  echo "✅ Completion system reloaded!"
  echo "💡 Try: cd <TAB> to test hidden directory completion"
}

