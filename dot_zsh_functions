# PERFORMANCE: Enhanced GitHub repository opener with better error handling
ghopen() {
  # PERFORMANCE: Check if we're in a git repository first
  if ! git rev-parse --git-dir >/dev/null 2>&1; then
    echo "❌ Not a Git repository"
    return 1
  fi
  
  # PERFORMANCE: Get remote URL more efficiently
  local url
  url=$(git remote get-url origin 2>/dev/null)
  
  if [[ -z "$url" ]]; then
    echo "❌ No 'origin' remote found"
    return 1
  fi
  
  # PERFORMANCE: Convert SSH to HTTPS URL more robustly
  case "$url" in
    git@github.com:*) 
      url="https://github.com/${url#git@github.com:}"
      url="${url%.git}"
      ;;
    https://github.com/*)
      url="${url%.git}"
      ;;
    *)
      echo "❌ Not a GitHub repository"
      return 1
      ;;
  esac
  
  echo "🌐 Opening: $url"
  
  # PERFORMANCE: macOS browser opening
  if [[ "$(uname)" == "Darwin" ]]; then
    open "$url"
  else
    echo "❌ Unsupported platform for browser opening"
  fi
}

